{
  "name": "vm-extractor",
  "version": "1.0.0",
  "private": true,
  "description": "Headless sync of Vita Mojo (VM Hub) MP1 reporting into Supabase (Postgres) for Pickers.",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "auth": "node src/auth.js",
    "auto-auth": "node src/auto-auth.js",
    "sync": "node src/index.js",
    "inspect": "node src/inspect.js",
    "api-start": "node server.js",
    "api-dev": "nodemon server.js",
    "init-views": "psql \"$SUPABASE_DB_URL\" -f sql/kpi_views.sql"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.0",
    "pg": "^8.12.0",
    "playwright": "^1.45.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
