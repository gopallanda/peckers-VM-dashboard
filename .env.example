# ---------------------------------------------------------------------------
# Vita Mojo (VM Hub) credentials
# ---------------------------------------------------------------------------
VM_HUB_URL=https://hub.vitamojo.com
VM_HUB_EMAIL=Peckersstevenage@hotmail.com
# Only used by `npm run auth` (headed, interactive). NEVER auto-typed in
# unattended runs. Leave blank if you prefer to type it by hand in the browser.
VM_HUB_PASSWORD=Peckers2024

# ---------------------------------------------------------------------------
# Supabase project (provided)
# ---------------------------------------------------------------------------
SUPABASE_PROJECT_URL=https://jrmvvlkcwjaqruoyevyg.supabase.co
# Publishable key is READ-ONLY and is NOT used for writes. Kept for reference.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_w1k5jPmVifrYySpRRs8_Ag_G2G3VjrF

# REQUIRED for writes. Supabase > Project Settings > Database > Connection
# string > URI. Use the connection-pooler URI and fill in <region> + password.
SUPABASE_DB_URL=postgresql://postgres.jrmvvlkcwjaqruoyevyg:__db_password__@aws-0-<region>.pooler.supabase.com:5432/postgres

# ---------------------------------------------------------------------------
# Sync configuration
# ---------------------------------------------------------------------------
# Stores to sync (comma-separated, EXACT names as shown in the VM Hub filter).
# Test Store is intentionally excluded.
STORES=Peckers Hitchin,Peckers Stevenage

# How many complete Mon–Sun weeks to pull when START_DATE/END_DATE are not set.
WEEKS_BACK=4

# Explicit date-range override (YYYY-MM-DD). If BOTH are set they win over
# WEEKS_BACK. For the first one-off run the user wants this single week:
START_DATE=2026-06-01
END_DATE=2026-06-07

# ---------------------------------------------------------------------------
# Browser behaviour
# ---------------------------------------------------------------------------
# 1 = headless (default for scheduled runs). 0 = headed (debugging).
HEADLESS=1
# 1 = save step screenshots to ./debug to confirm selectors on first run.
DEBUG_SHOTS=0
